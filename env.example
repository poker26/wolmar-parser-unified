# Wolmar Parser Environment Variables
# Скопируйте этот файл в .env и настройте под ваши нужды
# Для self-hosted Supabase (sup.begemot26.ru) используйте значения из .env Supabase

# База данных (self-hosted Supabase)
DB_USER=postgres
DB_HOST=sup.begemot26.ru
DB_NAME=postgres
DB_PASSWORD=
# Для self-hosted Supabase укажите POSTGRES_PASSWORD из .env Supabase
DB_PORT=6543
# DB_SSL=true — для облачного Supabase; не задавать или false — для self-hosted без SSL

# Сервер
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# CORS
CORS_ORIGIN=*

# Безопасность (JWT для auth приложения, можно взять из Supabase JWT_SECRET)
JWT_SECRET=
BCRYPT_ROUNDS=12

# Supabase REST API (если потребуется)
# SUPABASE_URL=https://sup.begemot26.ru
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Логирование
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Chrome/Chromium путь (для Linux)
CHROME_PATH=/usr/bin/google-chrome

# Мониторинг
HEALTH_CHECK_INTERVAL=30000
MEMORY_THRESHOLD=1024
CPU_THRESHOLD=80